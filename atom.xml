&lt;img data-src=&#34;/assets/multimodal-android-malware-detection/multimodal-android-malware-detection-20240901-05.png&#34; alt=&#34;acc_compare&#34; /&gt;&lt;br /&gt;
&lt;img data-src=&#34;/assets/multimodal-android-malware-detection/multimodal-android-malware-detection-20240901-06.png&#34; alt=&#34;loss_compare&#34; /&gt;&lt;/p&gt;
&lt;h2 id=&#34;two-label-multimodal&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#two-label-multimodal&#34;&gt;#&lt;/a&gt; Two-label multimodal&lt;/h2&gt;
&lt;p&gt;Self-attention&lt;/p&gt;
&lt;p&gt;&lt;figure class=&#34;highlight cpp&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;8&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;9&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;Classification Report SA:&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;              precision    recall  f1-score   support&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;      Benign     &lt;span class=&#34;number&#34;&gt;0.9766&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9728&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9747&lt;/span&gt;       &lt;span class=&#34;number&#34;&gt;773&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     Malware     &lt;span class=&#34;number&#34;&gt;0.9918&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9930&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9924&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;2565&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    accuracy                         &lt;span class=&#34;number&#34;&gt;0.9883&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   macro avg     &lt;span class=&#34;number&#34;&gt;0.9842&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9829&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9836&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;weighted avg     &lt;span class=&#34;number&#34;&gt;0.9883&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9883&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9883&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;              &lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;/p&gt;
&lt;p&gt;Cross-attention&lt;/p&gt;
&lt;p&gt;&lt;figure class=&#34;highlight cpp&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;8&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;9&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;Classification Report CA:&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;              precision    recall  f1-score   support&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;      Benign     &lt;span class=&#34;number&#34;&gt;0.9728&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9702&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9715&lt;/span&gt;       &lt;span class=&#34;number&#34;&gt;773&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     Malware     &lt;span class=&#34;number&#34;&gt;0.9910&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9918&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9914&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;2565&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    accuracy                         &lt;span class=&#34;number&#34;&gt;0.9868&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   macro avg     &lt;span class=&#34;number&#34;&gt;0.9819&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9810&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9815&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;weighted avg     &lt;span class=&#34;number&#34;&gt;0.9868&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9868&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9868&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;/p&gt;
&lt;p&gt;LSTM&lt;/p&gt;
&lt;p&gt;&lt;figure class=&#34;highlight cpp&#34;&gt;&lt;table&gt;&lt;tr&gt;&lt;td class=&#34;gutter&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;1&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;2&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;3&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;4&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;5&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;6&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;7&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;8&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;9&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;td class=&#34;code&#34;&gt;&lt;pre&gt;&lt;span class=&#34;line&#34;&gt;Classification Report LSTM:&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;              precision    recall  f1-score   support&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;      Benign     &lt;span class=&#34;number&#34;&gt;0.9829&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9677&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9752&lt;/span&gt;       &lt;span class=&#34;number&#34;&gt;773&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;     Malware     &lt;span class=&#34;number&#34;&gt;0.9903&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9949&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9926&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;2565&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;    accuracy                         &lt;span class=&#34;number&#34;&gt;0.9886&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;   macro avg     &lt;span class=&#34;number&#34;&gt;0.9866&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9813&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9839&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;span class=&#34;line&#34;&gt;weighted avg     &lt;span class=&#34;number&#34;&gt;0.9886&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9886&lt;/span&gt;    &lt;span class=&#34;number&#34;&gt;0.9886&lt;/span&gt;      &lt;span class=&#34;number&#34;&gt;3338&lt;/span&gt;&lt;/span&gt;&lt;br&gt;&lt;/pre&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;/figure&gt;&lt;/p&gt;
&lt;h2 id=&#34;five-label-multimodal&#34;&gt;&lt;a class=&#34;anchor&#34; href=&#34;#five-label-multimodal&#34;&gt;#&lt;/a&gt; Five-label multimodal&lt;/h2&gt;
